{
  "name": "@codylabs/nestjs-redlock",
  "version": "0.0.1",
  "description": "Redis-based distributed lock module for NestJS, built on @codylabs/redlock",
  "license": "MIT",
  "author": "Cody Nguyen",
  "files": [
    "dist/**"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf .turbo node_modules dist",
    "prebuild": "rimraf dist",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@codylabs/typescript-configs": "workspace:*",
    "@nestjs/testing": "^11.1.24"
  },
  "peerDependencies": {
    "@codylabs/redlock": "workspace:*",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "redis": "^5.0.0"
  }
}
