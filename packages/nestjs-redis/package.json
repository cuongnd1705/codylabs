{
  "name": "@codylabs/nestjs-redis",
  "version": "0.0.8",
  "description": "Flexible, production-ready Redis client module for NestJS with multi-connection support, built on the modern node-redis client",
  "homepage": "https://github.com/cuongnd1705/codylabs#readme",
  "bugs": {
    "url": "https://github.com/cuongnd1705/codylabs/issues"
  },
  "license": "MIT",
  "author": "Cody Nguyen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuongnd1705/codylabs.git"
  },
  "files": [
    "dist/**"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf .turbo node_modules dist",
    "prebuild": "rimraf dist",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@codylabs/typescript-configs": "workspace:*",
    "@nestjs/testing": "^11.1.28"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "redis": "^6.0.0"
  }
}
