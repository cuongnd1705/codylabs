{
  "name": "@codylabs/casl-drizzle",
  "version": "0.0.1",
  "description": "CASL integration for Drizzle ORM — define and enforce permissions using Drizzle RQB v2 where syntax.",
  "license": "MIT",
  "author": "Cody Nguyen",
  "files": [
    "dist/**"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf .turbo node_modules dist",
    "prebuild": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ucast/core": "^2.0.0",
    "@ucast/js": "^4.0.1"
  },
  "devDependencies": {
    "@casl/ability": "^7.0.0",
    "@codylabs/typescript-configs": "workspace:*",
    "drizzle-orm": "1.0.0-rc.4-5d5b77c",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@casl/ability": "^7.0.0",
    "drizzle-orm": ">=1.0.0-0"
  }
}
