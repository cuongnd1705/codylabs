{
  "name": "@codylabs/helper-fns",
  "version": "0.0.6",
  "description": "Functional TypeScript utility library - modern, simple, typed, powerful",
  "homepage": "https://github.com/cuongnd1705/codylabs#readme",
  "bugs": {
    "url": "https://github.com/cuongnd1705/codylabs/issues"
  },
  "license": "MIT",
  "author": "Cody Nguyen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuongnd1705/codylabs.git"
  },
  "files": [
    "dist/**"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf .turbo node_modules dist",
    "prebuild": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@codylabs/typescript-configs": "workspace:*",
    "tsdown": "^0.22.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
