{
  "name": "codylabs",
  "description": "Cody's Labs",
  "homepage": "https://github.com/cuongnd1705/codylabs#readme",
  "bugs": {
    "url": "https://github.com/cuongnd1705/codylabs/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Cody Nguyen",
    "email": "cuongnd.work@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuongnd1705/codylabs.git"
  },
  "scripts": {
    "build": "turbo build",
    "clean": "rm -rf .turbo node_modules",
    "dev": "turbo dev",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky",
    "publish-packages": "turbo run build quality && changeset version && changeset publish",
    "test": "turbo test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@nestjs/common": "^11.1.23",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.23",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "packages/**/*.ts": [
      "pnpm lint",
      "pnpm fmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.3.0"
}
